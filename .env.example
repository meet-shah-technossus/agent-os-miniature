# Copy this file to .env and fill in your values.
# .env is git-ignored and never committed.

OPENAI_API_KEY=api_key_here
GITHUB_TOKEN=git_PAT_here

# ── Ollama (remote GPU via VPN) ───────────────────────────────────────────────
# Set OLLAMA_BASE_URL to the full URL of your remote Ollama service, e.g.
#   OLLAMA_BASE_URL=http://192.168.10.5:11434
# The port is included in the URL.  Leave as localhost if running locally.
OLLAMA_BASE_URL=http://localhost:11434
